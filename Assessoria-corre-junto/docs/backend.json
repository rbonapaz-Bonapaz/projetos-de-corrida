
{
  "entities": {
    "AthleteProfile": {
      "title": "Perfil do Atleta",
      "description": "Dados completos do atleta incluindo fisiologia, nutrição e força.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerUid": { "type": "string" },
        "athleteEmail": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "currentWeight": { "type": "number" },
        "height": { "type": "number" },
        "restingHr": { "type": "number" },
        "vo2Max": { "type": "number" },
        "thresholdPace": { "type": "string" },
        "thresholdHr": { "type": "number" },
        "raceName": { "type": "string" },
        "raceDistance": { "type": "string" },
        "raceDate": { "type": "string", "format": "date" },
        "targetPace": { "type": "string" },
        "targetTime": { "type": "string" },
        "trainingDays": { "type": "array", "items": { "type": "string" } },
        "longRunDay": { "type": "string" },
        "weeklyMileageGoal": { "type": "number" },
        "planGenerationType": { "type": "string", "enum": ["full", "blocks"] },
        "experienceLevel": { "type": "string" },
        "trainingHistory": { "type": "string" },
        "referenceDocumentUri": { "type": "string" },
        "trainingPlan": { "type": "object" }
      }
    },
    "UserData": {
      "title": "Dados do Usuário",
      "type": "object",
      "properties": {
        "apiKey": { "type": "string" },
        "lastActiveProfileId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/user_data/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserData" },
      "description": "Configurações de API e estado do usuário."
    },
    "/athletes/{athleteId}": {
      "schema": { "$ref": "#/backend/entities/AthleteProfile" },
      "description": "Perfis e planilhas de treinamento dos atletas."
    }
  }
}
