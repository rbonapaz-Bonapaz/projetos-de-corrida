rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regras para dados de configuração e chat do usuário
    match /user_data/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Dados pessoais das calculadoras (records, estratégias, perfil de pace).
    // Cada usuário só acessa a própria subárvore users/{uid}/**.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regras para perfis de atletas e planilhas
    match /athletes/{athleteId} {
      // Leitura/edição: dono (ownerUid) ou atleta cujo e-mail bate com o perfil.
      allow read, update, delete: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid ||
        resource.data.athleteEmail == request.auth.token.email
      );
      // Criação: apenas logado e definindo a si mesmo como dono (evita
      // criar documentos em nome de terceiros).
      allow create: if request.auth != null &&
        request.resource.data.ownerUid == request.auth.uid;
    }

    // Metadados de fotos de progresso (a foto em si vai pro Storage — ver
    // storage.rules; aqui só data/nota/comentário da IA, dono sempre exigido).
    match /progress_photos/{photoId} {
      allow read, delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.ownerUid == request.auth.uid &&
        request.resource.data.ownerUid == request.auth.uid;
    }
  }
}
